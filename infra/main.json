              }
            },
            "retentionInDays": {
              "type": "int",
              "defaultValue": 30,
              "minValue": 30,
              "maxValue": 730,
              "metadata": {
                "description": "Retention period in days for Log Analytics. Default 30, max 730."
              }
            },
            "extraTags": {
              "type": "object",
              "defaultValue": {},
              "metadata": {
                "description": "Extra tags merged into the defaults."
