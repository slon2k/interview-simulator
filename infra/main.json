    },
    "extraTags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Extra tags merged into the resource defaults."
      }
    }
  },
  "variables": {
    "appNameSuffix": "[take(uniqueString(subscription().id, resourceGroup().id, parameters('baseName'), parameters('environment')), 6)]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
